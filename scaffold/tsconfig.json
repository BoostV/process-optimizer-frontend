{
  "compilerOptions": {
    // TS 6.0 deprecates `moduleResolution: "node"` (node10) and `baseUrl`,
    // both still used across these packages. This silences the deprecation
    // until they are migrated (e.g. to moduleResolution "bundler") before TS 7.0.
    "ignoreDeprecations": "6.0",
    "composite": true,
    "declarationDir": "dist",
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext",
    "allowJs": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noImplicitAny": true,
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "declaration": true,
    "noEmit": true,
    "noEmitOnError": true
  }
}
